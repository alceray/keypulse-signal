<UserControl
  x:Class="KeyPulse.Views.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  Height="Auto"
  Width="Auto"
>
  <Grid Margin="16">
    <StackPanel>
      <CheckBox
        Content="Launch on login"
        IsChecked="{Binding LaunchOnLogin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        Margin="0,0,0,10"
      />

      <CheckBox
        Content="Install updates automatically"
        IsChecked="{Binding AutoInstallUpdates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        Margin="0,0,0,10"
      />

      <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
        <TextBlock Text="Keep per-minute activity for:" VerticalAlignment="Center" />
        <ComboBox
          Margin="8,0,0,0"
          Width="120"
          ItemsSource="{Binding RetentionChoices}"
          SelectedItem="{Binding SelectedRetentionOption, Mode=TwoWay}"
          DisplayMemberPath="Label"
        />
        <iconPacks:PackIconPhosphorIcons
          Kind="Info"
          Width="14"
          Height="14"
          Foreground="#666666"
          Margin="6,0,0,0"
          VerticalAlignment="Center"
          ToolTipService.ShowDuration="30000"
        >
          <iconPacks:PackIconPhosphorIcons.ToolTip>
            <ToolTip MaxWidth="320">
              <TextBlock
                TextWrapping="Wrap"
                Text="Limits how long a minute-by-minute record of your input activity is stored, for privacy reasons and to keep the database compact. Charts, calendar history, and lifetime totals are unaffected."
              />
            </ToolTip>
          </iconPacks:PackIconPhosphorIcons.ToolTip>
        </iconPacks:PackIconPhosphorIcons>
      </StackPanel>

      <Grid Margin="0,0,0,10">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Column="0" Text="{Binding CurrentVersionDisplay}" VerticalAlignment="Center" />

        <Button
          Grid.Column="1"
          Margin="8,0,0,0"
          Padding="10,4"
          Command="{Binding UpdateActionCommand}"
          Content="{Binding UpdateActionButtonText}"
        />
      </Grid>
    </StackPanel>

    <local:StatusMessagePanel
      HorizontalAlignment="Left"
      VerticalAlignment="Bottom"
      Margin="0,0,0,8"
      StatusMessage="{Binding StatusMessage}"
      StatusVisibility="{Binding StatusVisibility}"
    />
  </Grid>
</UserControl>
