<UserControl
  x:Class="KeyPulse.Views.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:local="clr-namespace:KeyPulse.Views"
  Height="Auto"
  Width="Auto"
>
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
  </UserControl.Resources>

  <Grid Margin="16">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel MaxWidth="520" HorizontalAlignment="Left" Margin="0,0,0,32">

        <Border Style="{StaticResource SectionCardStyle}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <iconPacks:PackIconPhosphorIcons Kind="Gear" Width="16" Height="16" VerticalAlignment="Center" Foreground="Black" />
              <TextBlock Text="General" Style="{StaticResource SectionTitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource SectionDividerStyle}" />

            <CheckBox
              Content="Launch on login"
              IsChecked="{Binding LaunchOnLogin, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              Margin="0,0,0,10"
            />

            <CheckBox
              Content="Keep running in the background when closed"
              IsChecked="{Binding CloseToTray, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              Visibility="{Binding ShowCloseToTrayOption, Converter={StaticResource BoolToVisibility}}"
            />
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCardStyle}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <iconPacks:PackIconPhosphorIcons Kind="Database" Width="16" Height="16" VerticalAlignment="Center" Foreground="Black" />
              <TextBlock Text="Data" Style="{StaticResource SectionTitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource SectionDividerStyle}" />

            <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
              <TextBlock Text="Keep per-minute activity for:" VerticalAlignment="Center" />
              <ComboBox
                Margin="8,0,0,0"
                Width="120"
                ItemsSource="{Binding RetentionChoices}"
                SelectedItem="{Binding SelectedRetentionOption, Mode=TwoWay}"
                DisplayMemberPath="Label"
              />
              <local:InfoHint
                Text="Limits how long a minute-by-minute record of your input activity is stored, for privacy reasons and to keep the database compact. Charts, calendar history, and lifetime totals are unaffected."
                Margin="6,0,0,0"
                VerticalAlignment="Center"
              />
            </StackPanel>

            <StackPanel Visibility="{Binding HasHiddenDevices, Converter={StaticResource BoolToVisibility}}">
              <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                <TextBlock
                  Text="Hidden devices"
                  VerticalAlignment="Center"
                  Foreground="{x:Static config:AppColorPalette.MutedBrush}"
                />
                <local:InfoHint
                  Text="Devices you have hidden from the dashboard and calendar. Unhide to show them again. Tracking continues either way."
                  Margin="6,0,0,0"
                  VerticalAlignment="Center"
                />
              </StackPanel>

              <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding HiddenDevices}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <DockPanel Margin="0,0,8,6">
                        <Button
                          DockPanel.Dock="Right"
                          Content="Unhide"
                          Padding="10,2"
                          Margin="8,0,0,0"
                          VerticalAlignment="Center"
                          Command="{Binding DataContext.UnhideDeviceCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                          CommandParameter="{Binding}"
                        />
                        <TextBlock Text="{Binding DeviceName}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
                      </DockPanel>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </StackPanel>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource SectionCardStyle}">
          <StackPanel>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
              <iconPacks:PackIconPhosphorIcons Kind="ArrowsClockwise" Width="16" Height="16" VerticalAlignment="Center" Foreground="Black" />
              <TextBlock Text="Updates" Style="{StaticResource SectionTitleStyle}" />
            </StackPanel>
            <Border Style="{StaticResource SectionDividerStyle}" />

            <CheckBox
              Content="Install updates automatically"
              IsChecked="{Binding AutoInstallUpdates, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              Margin="0,0,0,12"
            />

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Column="0" Text="{Binding CurrentVersionDisplay}" VerticalAlignment="Center" />

              <Button
                Grid.Column="1"
                HorizontalAlignment="Right"
                Margin="8,0,0,0"
                Padding="10,4"
                Command="{Binding UpdateActionCommand}"
                Content="{Binding UpdateActionButtonText}"
              />
            </Grid>
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>

    <local:ToastMessagePanel
      HorizontalAlignment="Left"
      VerticalAlignment="Bottom"
      Margin="0,0,0,8"
      ToastMessage="{Binding ToastMessage}"
      ToastVisibility="{Binding ToastVisibility}"
    />
  </Grid>
</UserControl>
