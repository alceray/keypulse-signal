<UserControl
  x:Class="KeyPulse.Views.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:oxy="http://oxyplot.org/wpf"
  Height="Auto"
  Width="Auto"
>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,8">
      <UniformGrid Columns="3" Margin="0,0,0,6">
        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Connected Devices" FontWeight="Bold" />
            <TextBlock Text="{Binding ConnectedDevices}" FontSize="20" />
            <TextBlock Text="{Binding ConnectedDevicesBreakdown}" Foreground="#666666" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Top Keyboards by Connected Time" FontWeight="Bold" />
            <TextBlock Text="{Binding TopKeyboardsSummary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Top Mice by Connected Time" FontWeight="Bold" />
            <TextBlock Text="{Binding TopMiceSummary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Grid Margin="4,0,4,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <ComboBox
          Grid.Column="0"
          Width="120"
          Margin="0,0,8,0"
          ItemsSource="{Binding RangeOptions}"
          SelectedItem="{Binding SelectedRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        />

        <ComboBox
          Grid.Column="1"
          Width="80"
          Margin="0,0,8,0"
          ToolTip="Bucket size (minutes)"
          ItemsSource="{Binding BucketSizeOptions}"
          SelectedItem="{Binding SelectedBucketMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        />

        <ComboBox
          Grid.Column="2"
          Width="80"
          Margin="0,0,8,0"
          ToolTip="Smoothing window (number of buckets)"
          ItemsSource="{Binding SmoothingWindowOptions}"
          SelectedItem="{Binding SelectedSmoothingWindow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        />

        <Button Grid.Column="3" Margin="0,0,8,0" Padding="10,4" Command="{Binding RefreshCommand}">Refresh</Button>

        <TextBlock
          Grid.Column="5"
          Text="{Binding LastUpdatedText}"
          HorizontalAlignment="Right"
          VerticalAlignment="Center"
          Foreground="#666666"
        />
      </Grid>
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <oxy:PlotView
        Grid.Row="0"
        Grid.Column="0"
        Margin="4"
        Model="{Binding KeyboardConnectionTimePiePlot}"
        Controller="{Binding PieHoverController}"
      />
      <oxy:PlotView
        Grid.Row="0"
        Grid.Column="1"
        Margin="4"
        Model="{Binding MouseConnectionTimePiePlot}"
        Controller="{Binding PieHoverController}"
      />

      <oxy:PlotView
        Grid.Row="1"
        Grid.Column="0"
        Grid.ColumnSpan="2"
        Margin="4"
        Model="{Binding InputActivityPlot}"
        Controller="{Binding PieHoverController}"
      />
    </Grid>
  </Grid>
</UserControl>
