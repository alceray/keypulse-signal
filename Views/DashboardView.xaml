<UserControl
  x:Class="KeyPulse.Views.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:oxy="http://oxyplot.org/wpf"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  Height="Auto"
  Width="Auto"
>
  <UserControl.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Styles/RoundHoverIconButtonStyle.xaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,8">
      <UniformGrid Columns="3" Margin="0,0,0,6">
        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Connected Devices" FontWeight="Bold" />
            <TextBlock Text="{Binding ConnectedDevices}" FontSize="20" />
            <TextBlock Text="{Binding ConnectedDevicesBreakdown}" Foreground="#666666" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Top Keyboards by Connected Time" FontWeight="Bold" />
            <TextBlock Text="{Binding TopKeyboardsSummary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>

        <Border Margin="4" Padding="10" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4">
          <StackPanel>
            <TextBlock Text="Top Mice by Connected Time" FontWeight="Bold" />
            <TextBlock Text="{Binding TopMiceSummary}" TextWrapping="Wrap" Margin="0,4,0,0" />
          </StackPanel>
        </Border>
      </UniformGrid>

      <Grid Margin="4,0,4,0">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <ComboBox
          Grid.Column="0"
          Width="120"
          Margin="0,0,8,0"
          ItemsSource="{Binding RangeOptions}"
          SelectedItem="{Binding SelectedRange, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          VerticalAlignment="Center"
        />

        <TextBlock
          Grid.Column="1"
          Text="{Binding RangeDisplayText}"
          VerticalAlignment="Center"
          HorizontalAlignment="Center"
          Foreground="#666666"
          FontWeight="SemiBold"
        />

        <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
          <TextBlock Text="{Binding LastUpdatedText}" VerticalAlignment="Center" Foreground="#666666" />
          <Button
            Margin="4,0,0,0"
            Command="{Binding RefreshCommand}"
            ToolTip="Refresh"
            VerticalAlignment="Center"
            Style="{StaticResource RoundHoverIconButtonStyle}"
          >
            <iconPacks:PackIconPhosphorIcons Kind="ArrowClockwise" VerticalAlignment="Center" Foreground="#666" />
          </Button>
        </StackPanel>
      </Grid>
    </StackPanel>

    <Grid Grid.Row="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="*" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="*" />
      </Grid.ColumnDefinitions>

      <oxy:PlotView
        Grid.Row="0"
        Grid.Column="0"
        Margin="4"
        Model="{Binding KeyboardConnectionTimePiePlot}"
        Controller="{Binding PieHoverController}"
      />
      <oxy:PlotView
        Grid.Row="0"
        Grid.Column="1"
        Margin="4"
        Model="{Binding MouseConnectionTimePiePlot}"
        Controller="{Binding PieHoverController}"
      />

      <oxy:PlotView
        Grid.Row="1"
        Grid.Column="0"
        Grid.ColumnSpan="2"
        Margin="4"
        Model="{Binding InputActivityPlot}"
        Controller="{Binding PieHoverController}"
      />
    </Grid>
  </Grid>
</UserControl>
