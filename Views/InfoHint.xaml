<UserControl
  x:Class="KeyPulse.Views.InfoHint"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  x:Name="Root"
>
  <Border
    Background="Transparent"
    Tag="{Binding Text, ElementName=Root}"
    ToolTipService.ShowDuration="30000"
  >
    <Border.ToolTip>
      <ToolTip MaxWidth="320">
        <TextBlock
          TextWrapping="Wrap"
          Text="{Binding PlacementTarget.Tag, RelativeSource={RelativeSource AncestorType=ToolTip}}"
        />
      </ToolTip>
    </Border.ToolTip>
    <iconPacks:PackIconPhosphorIcons
      Kind="Info"
      Width="14"
      Height="14"
      Foreground="{x:Static config:AppColorPalette.SecondaryTextBrush}"
    />
  </Border>
</UserControl>
