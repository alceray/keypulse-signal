<UserControl
  x:Class="KeyPulse.Views.CalendarView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:vm="clr-namespace:KeyPulse.ViewModels.Calendar"
  IsVisibleChanged="CalendarView_IsVisibleChanged"
  Focusable="True"
  PreviewKeyDown="CalendarView_PreviewKeyDown"
  PreviewKeyUp="CalendarView_PreviewKeyUp"
>
  <UserControl.Resources>
    <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <local:SecondsToDisplayConverter x:Key="SecondsToDisplayConverter" />
    <local:MinutesToDisplayConverter x:Key="MinutesToDisplayConverter" />
    <local:IsMouseConverter x:Key="IsMouseConverter" />
    <local:IsKeyboardConverter x:Key="IsKeyboardConverter" />
    <local:MinWidthToVisibilityConverter x:Key="MinWidthToVisibilityConverter" />
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="0.3*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Month grid -->
    <Grid Grid.Column="0" Margin="0,0,8,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Month nav header -->
      <Grid Grid.Row="0" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button
          Grid.Column="0"
          Content="◀"
          Width="32"
          Height="28"
          Command="{Binding PreviousMonthCommand}"
          IsEnabled="{Binding CanGoPrevious}"
        />
        <TextBlock
          Grid.Column="1"
          Text="{Binding MonthTitle}"
          FontSize="16"
          FontWeight="Bold"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
        />
        <Button
          Grid.Column="2"
          Content="▶"
          Width="32"
          Height="28"
          Command="{Binding NextMonthCommand}"
          IsEnabled="{Binding CanGoNext}"
          Margin="0,0,0,0"
        />
      </Grid>

      <!-- Day-of-week header row -->
      <Grid Grid.Row="1" Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Mon" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="1" Text="Tue" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="2" Text="Wed" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="3" Text="Thu" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="4" Text="Fri" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="5" Text="Sat" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
        <TextBlock Grid.Column="6" Text="Sun" HorizontalAlignment="Center" FontWeight="SemiBold" Foreground="#666" />
      </Grid>

      <!-- Loading overlay / grid -->
      <Grid Grid.Row="2">
        <TextBlock
          Text="Loading…"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="#888"
          Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
        />

        <ItemsControl
          x:Name="CalendarGrid"
          ItemsSource="{Binding CalendarGridItems}"
          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
        >
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="7" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ContentControl Content="{Binding}">
                <ContentControl.Style>
                  <Style TargetType="ContentControl">
                    <!-- Default template: day tile -->
                    <Setter Property="ContentTemplate">
                      <Setter.Value>
                        <DataTemplate DataType="{x:Type vm:CalendarDaySummary}">
                          <Border
                            Margin="2"
                            VerticalAlignment="Stretch"
                            Padding="6"
                            CornerRadius="4"
                            Cursor="Hand"
                            MouseLeftButtonUp="DayTile_MouseLeftButtonUp"
                          >
                            <Border.Style>
                              <Style TargetType="Border">
                                <Setter Property="BorderThickness" Value="1" />
                                <Setter Property="BorderBrush" Value="#DDDDDD" />
                                <Setter Property="Background" Value="#FAFAFA" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding HasData}" Value="True">
                                    <Setter
                                      Property="Background"
                                      Value="{x:Static config:AppStyles.CalendarDataTileBackgroundBrush}"
                                    />
                                    <Setter
                                      Property="BorderBrush"
                                      Value="{x:Static config:AppStyles.CalendarDataTileBorderBrush}"
                                    />
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding HasData}" Value="False">
                                    <Setter Property="Background" Value="#F5F5F5" />
                                    <Setter Property="BorderBrush" Value="#EEEEEE" />
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter Property="BorderThickness" Value="3" />
                                    <Setter
                                      Property="BorderBrush"
                                      Value="{x:Static config:AppStyles.CalendarSelectedTileBorderBrush}"
                                    />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                              </Grid.RowDefinitions>
                              <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock
                                  DockPanel.Dock="Left"
                                  Text="{Binding Day.Day}"
                                  FontWeight="Bold"
                                  FontSize="16"
                                />
                                <TextBlock
                                  DockPanel.Dock="Right"
                                  Text="today"
                                  FontSize="12"
                                  Foreground="#429CF4"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding IsToday, Converter={StaticResource BoolToVisibilityConverter}}"
                                />
                              </DockPanel>
                              <ScrollViewer
                                Grid.Row="1"
                                Margin="0,3,0,0"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{Binding HasData, Converter={StaticResource BoolToVisibilityConverter}}"
                              >
                                <ItemsControl ItemsSource="{Binding Devices}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CalendarTileDevice}">
                                      <Grid Margin="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" />
                                          <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                          Grid.Column="0"
                                          Text="{Binding TypeIcon}"
                                          FontSize="12"
                                          Margin="0,0,3,0"
                                          VerticalAlignment="Center"
                                        />
                                        <TextBlock
                                          Grid.Column="1"
                                          Text="{Binding DeviceName}"
                                          FontSize="12"
                                          TextTrimming="CharacterEllipsis"
                                          VerticalAlignment="Center"
                                        />
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </Setter.Value>
                    </Setter>
                    <!-- Null item = blank spacer cell -->
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding}" Value="{x:Null}">
                        <Setter Property="ContentTemplate">
                          <Setter.Value>
                            <DataTemplate>
                              <Border Margin="2" VerticalAlignment="Stretch" Background="Transparent" />
                            </DataTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ContentControl.Style>
              </ContentControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Grid>

    <!-- Right: Day detail panel -->
    <Grid Grid.Column="1">
      <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="4" Padding="12">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <!-- No day selected -->
            <TextBlock
              Text="Select a day to see details"
              Foreground="#888"
              HorizontalAlignment="Center"
              Margin="0,40,0,0"
              Visibility="{Binding HasSelectedDay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
            />

            <!-- Day selected -->
            <StackPanel Visibility="{Binding HasSelectedDay, Converter={StaticResource BoolToVisibilityConverter}}">
              <TextBlock
                Text="{Binding SelectedDayTitle}"
                FontWeight="Bold"
                FontSize="14"
                Margin="0,0,0,8"
                TextWrapping="Wrap"
              />

              <ItemsControl ItemsSource="{Binding SelectedDayDetails}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:CalendarDeviceDetail}">
                    <Border BorderBrush="#E8E8E8" BorderThickness="1" CornerRadius="3" Padding="8" Margin="0,0,0,8">
                      <StackPanel>
                        <TextBlock Text="{Binding DeviceName}" FontWeight="SemiBold" TextWrapping="Wrap" />
                        <TextBlock Text="{Binding DeviceTypeText}" Foreground="#777" />

                        <StackPanel Margin="0,6,0,0" Orientation="Vertical" TextElement.FontSize="12">
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Connected time" Foreground="#555" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding ConnectionDuration, Converter={StaticResource SecondsToDisplayConverter}}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Height="6"
                            Margin="0,0,0,6"
                            Minimum="0"
                            Maximum="86400"
                            Value="{Binding ConnectionDuration, Mode=OneWay}"
                            FlowDirection="LeftToRight"
                            Foreground="#4A90E2"
                            Background="#EAEAEA"
                          />
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Longest session" Foreground="#555" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding LongestSessionDuration, Converter={StaticResource SecondsToDisplayConverter}}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Height="6"
                            Margin="0,0,0,6"
                            Minimum="0"
                            Maximum="86400"
                            Value="{Binding LongestSessionDuration, Mode=OneWay}"
                            FlowDirection="LeftToRight"
                            Foreground="#7DA5D8"
                            Background="#EAEAEA"
                          />
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Active time" Foreground="#555" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding ActiveMinutes, Converter={StaticResource MinutesToDisplayConverter}}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Height="6"
                            Margin="0,0,0,6"
                            Minimum="0"
                            Maximum="1440"
                            Value="{Binding ActiveMinutes, Mode=OneWay}"
                            FlowDirection="LeftToRight"
                            Foreground="#50C878"
                            Background="#EAEAEA"
                          />
                          <DockPanel
                            Margin="0,0,0,3"
                            Visibility="{Binding DeviceType, Converter={StaticResource IsMouseConverter}}"
                          >
                            <TextBlock DockPanel.Dock="Left" Text="Mouse movement time" Foreground="#555" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding LiveMouseMovementSeconds, Converter={StaticResource SecondsToDisplayConverter}}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Height="6"
                            Margin="0,0,0,6"
                            Minimum="0"
                            Maximum="86400"
                            Value="{Binding LiveMouseMovementSeconds, Mode=OneWay}"
                            FlowDirection="LeftToRight"
                            Foreground="#7FD9A8"
                            Background="#EAEAEA"
                            Visibility="{Binding DeviceType, Converter={StaticResource IsMouseConverter}}"
                          />
                          <DockPanel
                            Margin="0,0,0,8"
                            Visibility="{Binding DeviceType, Converter={StaticResource IsKeyboardConverter}}"
                          >
                            <TextBlock DockPanel.Dock="Left" Foreground="#555" Text="Keystrokes" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding LiveKeystrokes}"
                            />
                          </DockPanel>
                          <DockPanel
                            Margin="0,0,0,8"
                            Visibility="{Binding DeviceType, Converter={StaticResource IsMouseConverter}}"
                          >
                            <TextBlock DockPanel.Dock="Left" Foreground="#555" Text="Mouse clicks" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding LiveMouseClicks}"
                            />
                          </DockPanel>
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Sessions" Foreground="#555" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Foreground="#222"
                              TextAlignment="Right"
                              Text="{Binding SessionCount}"
                            />
                          </DockPanel>
                          <TextBlock Text="Input activity" Foreground="#555" Margin="0,4,0,2" />
                          <Border Padding="4,4,4,2" Margin="0,0,0,4">
                            <StackPanel>
                              <ItemsControl ItemsSource="{Binding HourlyInputBars}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <UniformGrid Columns="24" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border
                                      Height="48"
                                      Margin="0,0.7,0,0.7"
                                      VerticalAlignment="Bottom"
                                      Background="Transparent"
                                    >
                                      <Border.ToolTip>
                                        <ToolTip>
                                          <TextBlock Text="{Binding Tooltip}" />
                                        </ToolTip>
                                      </Border.ToolTip>
                                      <Rectangle
                                        Width="8"
                                        Height="{Binding BarHeight}"
                                        VerticalAlignment="Bottom"
                                        Fill="#8BB3E8"
                                      >
                                        <Rectangle.Style>
                                          <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="#8BB3E8" />
                                            <Style.Triggers>
                                              <DataTrigger Binding="{Binding IsPeak}" Value="True">
                                                <Setter Property="Fill" Value="#4A90E2" />
                                              </DataTrigger>
                                            </Style.Triggers>
                                          </Style>
                                        </Rectangle.Style>
                                      </Rectangle>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                              <ItemsControl
                                ItemsSource="{Binding HourlyInputBars}"
                                Margin="0,4,0,0"
                                ClipToBounds="False"
                              >
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <UniformGrid Columns="24" ClipToBounds="False" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                  <Style TargetType="ContentPresenter">
                                    <Setter Property="ClipToBounds" Value="False" />
                                  </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Grid ClipToBounds="False">
                                      <TextBlock
                                        Text="{Binding MajorLabel}"
                                        FontSize="9"
                                        Foreground="#777"
                                        HorizontalAlignment="Center"
                                        Margin="-20,0,-20,0"
                                      />
                                      <TextBlock
                                        Text="{Binding MinorLabel}"
                                        FontSize="9"
                                        Foreground="#777"
                                        HorizontalAlignment="Center"
                                        Margin="-20,0,-20,0"
                                        Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}, Path=ActualWidth, Converter={StaticResource MinWidthToVisibilityConverter}, ConverterParameter=200}"
                                      />
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
