<UserControl
  x:Class="KeyPulse.Views.CalendarView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:vm="clr-namespace:KeyPulse.ViewModels.Calendar"
  IsVisibleChanged="CalendarView_IsVisibleChanged"
  Focusable="True"
  PreviewKeyDown="CalendarView_PreviewKeyDown"
  PreviewKeyUp="CalendarView_PreviewKeyUp"
>
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <local:DurationSecondsConverter x:Key="DurationSecondsConverter" />
    <local:DeviceTypeToVisibilityConverter x:Key="DeviceTypeToVisibilityConverter" />
    <local:MinWidthToVisibilityConverter x:Key="MinWidthToVisibilityConverter" />
  </UserControl.Resources>
  <Grid Margin="8">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*" />
      <ColumnDefinition Width="0.3*" />
    </Grid.ColumnDefinitions>

    <!-- Left: Month grid -->
    <Grid Grid.Column="0" Margin="0,0,8,0">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Month nav header -->
      <Grid Grid.Row="0" Margin="0,0,0,8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Button
          Grid.Column="0"
          Content="◀"
          Width="32"
          Height="28"
          Command="{Binding PreviousMonthCommand}"
          IsEnabled="{Binding CanGoPrevious}"
        />
        <TextBlock
          Grid.Column="1"
          Text="{Binding MonthTitle}"
          FontSize="16"
          FontWeight="Bold"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
        />
        <Button
          Grid.Column="2"
          Content="▶"
          Width="32"
          Height="28"
          Command="{Binding NextMonthCommand}"
          IsEnabled="{Binding CanGoNext}"
          Margin="0,0,0,0"
        />
      </Grid>

      <!-- Day-of-week header row -->
      <Grid Grid.Row="1" Margin="0,0,0,4">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" Text="Mon" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="1" Text="Tue" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="2" Text="Wed" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="3" Text="Thu" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="4" Text="Fri" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="5" Text="Sat" Style="{StaticResource DayOfWeekHeaderStyle}" />
        <TextBlock Grid.Column="6" Text="Sun" Style="{StaticResource DayOfWeekHeaderStyle}" />
      </Grid>

      <!-- Loading overlay / grid -->
      <Grid Grid.Row="2">
        <TextBlock
          Text="Loading…"
          HorizontalAlignment="Center"
          VerticalAlignment="Center"
          Foreground="{x:Static config:AppColorPalette.MutedBrush}"
          Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
        />

        <ItemsControl
          x:Name="CalendarGrid"
          ItemsSource="{Binding CalendarGridItems}"
          Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}"
        >
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <UniformGrid Columns="7" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <ContentControl Content="{Binding}" MouseLeftButtonUp="DayTile_MouseLeftButtonUp">
                <ContentControl.Style>
                  <Style TargetType="ContentControl">
                    <!-- Default template: day tile -->
                    <Setter Property="ContentTemplate">
                      <Setter.Value>
                        <DataTemplate DataType="{x:Type vm:CalendarDaySummary}">
                          <Border Margin="2" VerticalAlignment="Stretch" Padding="6" CornerRadius="4">
                            <Border.Style>
                              <Style TargetType="Border">
                                <!-- Only days with activity are clickable, so only they get the hand cursor. -->
                                <Setter Property="BorderThickness" Value="0" />
                                <Setter Property="Cursor" Value="Arrow" />
                                <Setter Property="Background" Value="{x:Static config:AppColorPalette.SurfaceBrush}" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding HasData}" Value="True">
                                    <Setter
                                      Property="Background"
                                      Value="{x:Static config:AppColorPalette.CalendarTileBackgroundBrush}"
                                    />
                                    <Setter Property="Cursor" Value="Hand" />
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                    <Setter
                                      Property="Background"
                                      Value="{x:Static config:AppColorPalette.CalendarSelectedTileBackgroundBrush}"
                                    />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Border.Style>
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                              </Grid.RowDefinitions>
                              <DockPanel Grid.Row="0" LastChildFill="False">
                                <TextBlock
                                  DockPanel.Dock="Left"
                                  Text="{Binding Day.Day}"
                                  FontWeight="Bold"
                                  FontSize="16"
                                />
                                <TextBlock
                                  DockPanel.Dock="Right"
                                  Text="today"
                                  FontSize="12"
                                  Foreground="{x:Static config:AppColorPalette.PrimaryTextBrush}"
                                  VerticalAlignment="Center"
                                  Visibility="{Binding IsToday, Converter={StaticResource BooleanToVisibilityConverter}}"
                                />
                              </DockPanel>
                              <ScrollViewer
                                Grid.Row="1"
                                Margin="0,3,0,0"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled"
                                Visibility="{Binding HasData, Converter={StaticResource BooleanToVisibilityConverter}}"
                              >
                                <ItemsControl ItemsSource="{Binding Devices}">
                                  <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:CalendarTileDevice}">
                                      <Grid Margin="0,1,0,0">
                                        <Grid.ColumnDefinitions>
                                          <ColumnDefinition Width="Auto" />
                                          <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                          Grid.Column="0"
                                          Text="{Binding TypeIcon}"
                                          FontSize="12"
                                          Margin="0,0,3,0"
                                          VerticalAlignment="Center"
                                        />
                                        <TextBlock
                                          Grid.Column="1"
                                          Text="{Binding DeviceName}"
                                          FontSize="12"
                                          TextTrimming="CharacterEllipsis"
                                          VerticalAlignment="Center"
                                          Style="{StaticResource ConnectedDeviceNameStyle}"
                                        />
                                      </Grid>
                                    </DataTemplate>
                                  </ItemsControl.ItemTemplate>
                                </ItemsControl>
                              </ScrollViewer>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </Setter.Value>
                    </Setter>
                    <!-- Null item = blank spacer cell -->
                    <Style.Triggers>
                      <DataTrigger Binding="{Binding}" Value="{x:Null}">
                        <Setter Property="ContentTemplate">
                          <Setter.Value>
                            <DataTemplate>
                              <Border Margin="2" VerticalAlignment="Stretch" Background="Transparent" />
                            </DataTemplate>
                          </Setter.Value>
                        </Setter>
                      </DataTrigger>
                    </Style.Triggers>
                  </Style>
                </ContentControl.Style>
              </ContentControl>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Grid>
    </Grid>

    <!-- Right: Day detail panel -->
    <Grid Grid.Column="1">
      <Border
        BorderBrush="{x:Static config:AppColorPalette.BorderBrush}"
        BorderThickness="1"
        CornerRadius="4"
        Padding="12"
      >
        <ScrollViewer VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <!-- No day selected -->
            <TextBlock
              Text="Select a day to see details"
              Foreground="{x:Static config:AppColorPalette.MutedBrush}"
              HorizontalAlignment="Center"
              Margin="0,40,0,0"
              Visibility="{Binding HasSelectedDay, Converter={StaticResource InverseBoolToVisibilityConverter}}"
            />

            <!-- Day selected -->
            <StackPanel Visibility="{Binding HasSelectedDay, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock
                Text="{Binding SelectedDayTitle}"
                FontWeight="Bold"
                FontSize="14"
                Margin="0,0,0,8"
                TextWrapping="Wrap"
              />

              <ItemsControl ItemsSource="{Binding SelectedDayDetails}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate DataType="{x:Type vm:CalendarDeviceDetail}">
                    <Border Style="{StaticResource DayDetailCardStyle}">
                      <StackPanel>
                        <TextBlock
                          Text="{Binding DeviceName}"
                          FontWeight="SemiBold"
                          TextWrapping="Wrap"
                          Style="{StaticResource ConnectedDeviceNameStyle}"
                        />
                        <TextBlock
                          Text="{Binding DeviceTypeText}"
                          Foreground="{x:Static config:AppColorPalette.SecondaryTextBrush}"
                        />

                        <StackPanel Margin="0,6,0,0" Orientation="Vertical" TextElement.FontSize="12">
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Connected time" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Style="{StaticResource DetailValueStyle}"
                              Text="{Binding ConnectionSeconds, Converter={StaticResource DurationSecondsConverter}}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Style="{StaticResource ActivityProgressBarStyle}"
                            Maximum="86400"
                            Value="{Binding ConnectionSeconds, Mode=OneWay}"
                            Foreground="{x:Static config:AppColorPalette.ConnectedBrush}"
                          />
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Active time" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Style="{StaticResource DetailValueStyle}"
                              Text="{Binding ActiveTimeText}"
                            />
                          </DockPanel>
                          <ProgressBar
                            Style="{StaticResource ActivityProgressBarStyle}"
                            Maximum="86400"
                            Value="{Binding ActiveSeconds, Mode=OneWay}"
                            Foreground="{x:Static config:AppColorPalette.ActiveBrush}"
                          />
                          <DockPanel
                            Margin="0,0,0,8"
                            Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Keyboard}"
                          >
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource DetailLabelStyle}" Text="Keystrokes" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Style="{StaticResource DetailValueStyle}"
                              Text="{Binding Keystrokes}"
                            />
                          </DockPanel>
                          <DockPanel
                            Margin="0,0,0,8"
                            Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Mouse}"
                          >
                            <TextBlock DockPanel.Dock="Left" Style="{StaticResource DetailLabelStyle}" Text="Mouse clicks" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Style="{StaticResource DetailValueStyle}"
                              Text="{Binding MouseClicks}"
                            />
                          </DockPanel>
                          <DockPanel Margin="0,0,0,3">
                            <TextBlock DockPanel.Dock="Left" Text="Sessions" Style="{StaticResource DetailLabelStyle}" />
                            <TextBlock
                              DockPanel.Dock="Right"
                              Style="{StaticResource DetailValueStyle}"
                              Text="{Binding SessionCount}"
                            />
                          </DockPanel>
                          <TextBlock Text="Input activity" Style="{StaticResource DetailLabelStyle}" Margin="0,4,0,2" />
                          <Border Padding="4,4,4,2" Margin="0,0,0,4">
                            <StackPanel>
                              <ItemsControl ItemsSource="{Binding HourlyInputBars}">
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <UniformGrid Columns="24" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Border
                                      Height="48"
                                      Margin="0,0.7,0,0.7"
                                      VerticalAlignment="Bottom"
                                      Background="Transparent"
                                    >
                                      <Border.ToolTip>
                                        <ToolTip>
                                          <TextBlock Text="{Binding Tooltip}" />
                                        </ToolTip>
                                      </Border.ToolTip>
                                      <Rectangle Width="8" Height="{Binding BarHeight}" VerticalAlignment="Bottom">
                                        <Rectangle.Style>
                                          <Style TargetType="Rectangle">
                                            <Setter Property="Fill" Value="{x:Static config:AppColorPalette.ActiveBrush}" />
                                          </Style>
                                        </Rectangle.Style>
                                      </Rectangle>
                                    </Border>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                              <ItemsControl
                                ItemsSource="{Binding HourlyInputBars}"
                                Margin="0,4,0,0"
                                ClipToBounds="False"
                              >
                                <ItemsControl.ItemsPanel>
                                  <ItemsPanelTemplate>
                                    <UniformGrid Columns="24" ClipToBounds="False" />
                                  </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                  <Style TargetType="ContentPresenter">
                                    <Setter Property="ClipToBounds" Value="False" />
                                  </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                  <DataTemplate>
                                    <Grid ClipToBounds="False">
                                      <TextBlock
                                        Text="{Binding MajorLabel}"
                                        FontSize="9"
                                        Foreground="{x:Static config:AppColorPalette.SecondaryTextBrush}"
                                        HorizontalAlignment="Center"
                                        Margin="-20,0,-20,0"
                                      />
                                      <TextBlock
                                        Text="{Binding MinorLabel}"
                                        FontSize="9"
                                        Foreground="{x:Static config:AppColorPalette.SecondaryTextBrush}"
                                        HorizontalAlignment="Center"
                                        Margin="-20,0,-20,0"
                                        Visibility="{Binding RelativeSource={RelativeSource FindAncestor, AncestorType=ItemsControl}, Path=ActualWidth, Converter={StaticResource MinWidthToVisibilityConverter}, ConverterParameter=200}"
                                      />
                                    </Grid>
                                  </DataTemplate>
                                </ItemsControl.ItemTemplate>
                              </ItemsControl>
                            </StackPanel>
                          </Border>
                        </StackPanel>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </StackPanel>
        </ScrollViewer>
      </Border>
    </Grid>
  </Grid>
</UserControl>
