<UserControl
  x:Class="KeyPulse.Views.DeviceListView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  Height="Auto"
  Width="Auto"
>
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <local:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter" />
    <local:DurationSecondsConverter x:Key="DurationSecondsConverter" />
    <local:DeviceTypeToVisibilityConverter x:Key="DeviceTypeToVisibilityConverter" />
    <local:ActivityColorConverter x:Key="ActivityColorConverter" />
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Controls and Session Info Row -->
    <Grid Grid.Row="0" Margin="5">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <CheckBox
        Grid.Column="0"
        Content="Show All Devices"
        IsChecked="{Binding ShowAllDevices, Mode=TwoWay}"
        VerticalAlignment="Center"
      />

      <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
        <TextBlock Text="Current Session" FontWeight="Bold" TextAlignment="Right" />
        <TextBlock Text="{Binding CurrentSessionTime}" FontSize="16" TextAlignment="Right" />
      </StackPanel>
    </Grid>

    <!-- Device List -->
    <DataGrid
      Grid.Row="1"
      ItemsSource="{Binding DeviceListCollection}"
      AutoGenerateColumns="False"
      IsReadOnly="True"
      SelectionMode="Single"
      CanUserResizeColumns="False"
      CanUserResizeRows="False"
    >
      <DataGrid.Resources>
        <Style TargetType="DataGridRow">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="Black" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <EventSetter Event="PreviewMouseRightButtonDown" Handler="DataGridRow_PreviewMouseRightButtonDown" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="{x:Static config:AppColorPalette.SurfaceBrush}" />
            </Trigger>
          </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="Black" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
          <!-- Center cell content vertically while the Border still fills the row height. -->
          <Setter Property="Template">
            <Setter.Value>
              <ControlTemplate TargetType="DataGridCell">
                <Border
                  Background="{TemplateBinding Background}"
                  BorderBrush="{TemplateBinding BorderBrush}"
                  BorderThickness="{TemplateBinding BorderThickness}"
                >
                  <ContentPresenter VerticalAlignment="Center" />
                </Border>
              </ControlTemplate>
            </Setter.Value>
          </Setter>
        </Style>
      </DataGrid.Resources>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" MinWidth="175" Width="Auto" />
        <DataGridTemplateColumn Header="Device Type" SortMemberPath="DeviceType" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconPhosphorIcons
                  Kind="Keyboard"
                  Width="24"
                  Height="24"
                  Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Keyboard}"
                  Foreground="{Binding IsActive, Converter={StaticResource ActivityColorConverter}}"
                />
                <iconPacks:PackIconPhosphorIcons
                  Kind="Mouse"
                  Width="24"
                  Height="24"
                  Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Mouse}"
                  Foreground="{Binding IsActive, Converter={StaticResource ActivityColorConverter}}"
                />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="*" />
        <DataGridTextColumn
          Header="Last Connected"
          Binding="{Binding LastConnectedRelative}"
          SortMemberPath="LastConnectedAt"
          Width="Auto"
        />
        <DataGridTextColumn
          Header="Total Connected Time"
          Binding="{Binding TotalConnectionSeconds, Converter={StaticResource DurationSecondsConverter}}"
          MinWidth="80"
          Width="Auto"
        />
        <DataGridTextColumn Header="Total Inputs" Binding="{Binding TotalInputCount}" Width="Auto" />
        <DataGridTextColumn
          Header="Status"
          Binding="{Binding StatusText}"
          SortMemberPath="StatusSortOrder"
          SortDirection="Ascending"
          MinWidth="100"
          Width="Auto"
        >
          <DataGridTextColumn.CellStyle>
            <Style TargetType="DataGridCell">
              <Setter Property="BorderThickness" Value="0" />
              <Setter Property="BorderBrush" Value="Transparent" />
              <!-- Whole-cell color by status; default is disconnected (red). -->
              <Setter Property="Background" Value="{x:Static config:AppColorPalette.StatusDisconnectedBackgroundBrush}" />
              <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.StatusDisconnectedForegroundBrush}" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="DataGridCell">
                    <Border Background="{TemplateBinding Background}">
                      <ContentPresenter VerticalAlignment="Center" />
                    </Border>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
              <Style.Triggers>
                <DataTrigger Binding="{Binding StatusText}" Value="Connected">
                  <Setter Property="Background" Value="{x:Static config:AppColorPalette.StatusConnectedBackgroundBrush}" />
                  <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.StatusConnectedForegroundBrush}" />
                </DataTrigger>
                <DataTrigger Binding="{Binding StatusText}" Value="Hidden">
                  <Setter Property="Background" Value="{x:Static config:AppColorPalette.StatusHiddenBackgroundBrush}" />
                  <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.StatusHiddenForegroundBrush}" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </DataGridTextColumn.CellStyle>
        </DataGridTextColumn>
      </DataGrid.Columns>
      <DataGrid.ContextMenu>
        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
          <MenuItem
            Header="Rename Device"
            Command="{Binding RenameDeviceCommand}"
            CommandParameter="{Binding PlacementTarget.SelectedItem,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
          />
          <MenuItem
            Header="Hide Device"
            ToolTip="Hides this device from the dashboard and calendar. Tracking continues."
            Command="{Binding ToggleDeviceDisplayVisibilityCommand}"
            CommandParameter="{Binding PlacementTarget.SelectedItem,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
            Visibility="{Binding PlacementTarget.SelectedItem.IsHiddenFromDisplay, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource InverseBoolToVisibilityConverter}}"
          />
          <MenuItem
            Header="Unhide Device"
            ToolTip="Shows this device on the dashboard and calendar again."
            Command="{Binding ToggleDeviceDisplayVisibilityCommand}"
            CommandParameter="{Binding PlacementTarget.SelectedItem,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
            Visibility="{Binding PlacementTarget.SelectedItem.IsHiddenFromDisplay, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
          />
        </ContextMenu>
      </DataGrid.ContextMenu>
    </DataGrid>
  </Grid>
</UserControl>
