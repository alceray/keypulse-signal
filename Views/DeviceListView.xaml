<UserControl
  x:Class="KeyPulse.Views.DeviceListView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  Height="Auto"
  Width="Auto"
>
  <UserControl.Resources>
    <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    <local:SecondsToStringConverter x:Key="SecondsToStringConverter" />
    <local:DeviceTypeToVisibilityConverter x:Key="DeviceTypeToVisibilityConverter" />
    <local:ActivityColorConverter x:Key="ActivityColorConverter" />
  </UserControl.Resources>

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Controls and Session Info Row -->
    <Grid Grid.Row="0" Margin="5">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <CheckBox
        Grid.Column="0"
        Content="Show All Devices"
        IsChecked="{Binding ShowAllDevices, Mode=TwoWay}"
        VerticalAlignment="Center"
      />

      <StackPanel Grid.Column="2" Orientation="Vertical" HorizontalAlignment="Right">
        <TextBlock Text="Current Session" FontWeight="Bold" TextAlignment="Right" />
        <TextBlock Text="{Binding CurrentSessionTime}" FontSize="16" TextAlignment="Right" />
      </StackPanel>
    </Grid>

    <!-- Device List -->
    <DataGrid
      Grid.Row="1"
      ItemsSource="{Binding DeviceListCollection}"
      AutoGenerateColumns="False"
      IsReadOnly="True"
      SelectionMode="Single"
      CanUserResizeColumns="False"
      CanUserResizeRows="False"
    >
      <DataGrid.Resources>
        <Style TargetType="DataGridRow">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="Black" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Style.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter Property="Background" Value="#11000000" />
            </Trigger>
          </Style.Triggers>
        </Style>

        <Style TargetType="DataGridCell">
          <Setter Property="Background" Value="Transparent" />
          <Setter Property="Foreground" Value="Black" />
          <Setter Property="BorderBrush" Value="Transparent" />
          <Setter Property="BorderThickness" Value="0" />
        </Style>
      </DataGrid.Resources>
      <DataGrid.Columns>
        <DataGridTextColumn Header="Device ID" Binding="{Binding DeviceId}" MinWidth="175" Width="Auto" />
        <DataGridTemplateColumn Header="Device Type" Width="80">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <iconPacks:PackIconPhosphorIcons
                  Kind="Keyboard"
                  Width="24"
                  Height="24"
                  Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Keyboard}"
                  Foreground="{Binding IsActive, Converter={StaticResource ActivityColorConverter}}"
                />
                <iconPacks:PackIconPhosphorIcons
                  Kind="Mouse"
                  Width="24"
                  Height="24"
                  Visibility="{Binding DeviceType, Converter={StaticResource DeviceTypeToVisibilityConverter}, ConverterParameter=Mouse}"
                  Foreground="{Binding IsActive, Converter={StaticResource ActivityColorConverter}}"
                />
              </StackPanel>
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
        <DataGridTextColumn Header="Device Name" Binding="{Binding DeviceName}" Width="*" />
        <DataGridTextColumn Header="Total Input Count" Binding="{Binding TotalInputCount}" Width="Auto" />
        <DataGridTextColumn
          Header="Last Connected"
          Binding="{Binding LastConnectedRelative}"
          SortMemberPath="LastConnectedAt"
          Width="Auto"
        />
        <DataGridTextColumn
          Header="Total Connected Time"
          Binding="{Binding TotalConnectionSeconds, Converter={StaticResource SecondsToStringConverter}}"
          MinWidth="80"
          Width="Auto"
        />
        <DataGridTemplateColumn Header="Connected" Width="Auto">
          <DataGridTemplateColumn.CellTemplate>
            <DataTemplate>
              <TextBlock
                Text="✓"
                Visibility="{Binding IsConnected, Converter={StaticResource BooleanToVisibilityConverter}}"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
              />
            </DataTemplate>
          </DataGridTemplateColumn.CellTemplate>
        </DataGridTemplateColumn>
      </DataGrid.Columns>
      <DataGrid.ContextMenu>
        <ContextMenu>
          <MenuItem
            Header="Rename Device"
            Command="{Binding RenameDeviceCommand}"
            CommandParameter="{Binding PlacementTarget.SelectedItem,RelativeSource={RelativeSource AncestorType=ContextMenu}}"
          />
        </ContextMenu>
      </DataGrid.ContextMenu>
    </DataGrid>
  </Grid>
</UserControl>
