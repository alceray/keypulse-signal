<Window
  x:Class="KeyPulse.Views.CloseToTrayHintWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Width="440"
  SizeToContent="Height"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  WindowStartupLocation="CenterOwner"
>
  <Grid Margin="20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <TextBlock
      Grid.Row="0"
      Text="Still running in the background"
      FontSize="15"
      FontWeight="SemiBold"
      Margin="0,0,0,8"
    />

    <TextBlock
      Grid.Row="1"
      Text="Tracking continues after you close the window. To quit the app, right-click the tray icon and select Exit."
      TextWrapping="Wrap"
      Margin="0,0,0,18"
    />

    <CheckBox
      Grid.Row="2"
      x:Name="DontShowAgainCheckBox"
      Content="Don't show this again"
      Margin="0,0,0,18"
    />

    <Button
      Grid.Row="3"
      Content="OK"
      Width="84"
      Height="28"
      HorizontalAlignment="Right"
      IsDefault="True"
      Click="OnOkClick"
    />
  </Grid>
</Window>
