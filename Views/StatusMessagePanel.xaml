<UserControl
  x:Class="KeyPulse.Views.StatusMessagePanel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  x:Name="Root"
  Height="Auto"
  Width="Auto"
>
  <Border
    Padding="14,8"
    CornerRadius="6"
    Background="{x:Static config:AppStyles.StatusBackgroundBrush}"
    IsHitTestVisible="False"
    Visibility="{Binding StatusVisibility, ElementName=Root}"
  >
    <TextBlock Text="{Binding StatusMessage, ElementName=Root}" Foreground="White" FontSize="13" />
  </Border>
</UserControl>
