<UserControl
  x:Class="KeyPulse.Views.TroubleshootingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
  xmlns:local="clr-namespace:KeyPulse.Views"
  xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
  Height="Auto"
  Width="Auto"
  PreviewKeyDown="OnPreviewKeyDown"
>
  <Grid Margin="16">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Toolbar: [date] ... [search + filter] [refresh | copy | folder] -->
    <DockPanel Grid.Row="0" Margin="0,0,0,8" LastChildFill="True">
      <!-- Date picker -->
      <ComboBox
        DockPanel.Dock="Left"
        Width="{x:Static config:AppConstants+Troubleshooting.DatePickerWidth}"
        Margin="0,0,8,0"
        ItemsSource="{Binding LogFiles}"
        SelectedItem="{Binding SelectedLogFile, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
        DisplayMemberPath="DisplayDateText"
        VerticalContentAlignment="Center"
      />

      <!-- Right-side toolbar group: search/filter + actions -->
      <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
        <Grid Width="{x:Static config:AppConstants+Troubleshooting.SearchPanelWidth}" Margin="8,0,0,0">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>

          <!-- Search box with inline result counter -->
          <Grid Grid.Column="0">
            <TextBox
              x:Name="LogSearchTextBox"
              VerticalContentAlignment="Center"
              Padding="8,0,52,0"
              Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
              KeyDown="OnLogSearchTextBoxKeyDown"
            />
            <TextBlock
              x:Name="SearchResultCounterText"
              HorizontalAlignment="Right"
              VerticalAlignment="Center"
              Margin="0,0,8,0"
              Foreground="{x:Static config:AppStyles.SearchCounterBrush}"
              IsHitTestVisible="False"
              Visibility="Collapsed"
            />
          </Grid>

          <!-- Filter popup -->
          <Grid Grid.Column="1" Margin="4,0,0,0">
            <ToggleButton x:Name="FilterToggle" Width="32" Height="32" ToolTip="Filter by level">
              <iconPacks:PackIconPhosphorIcons Kind="Funnel" Width="15" Height="15" />
            </ToggleButton>
            <Popup
              IsOpen="{Binding IsChecked, ElementName=FilterToggle, Mode=TwoWay}"
              StaysOpen="False"
              PlacementTarget="{Binding ElementName=FilterToggle}"
              Placement="Bottom"
            >
              <Border
                Background="{DynamicResource {x:Static SystemColors.WindowBrushKey}}"
                BorderBrush="#66000000"
                BorderThickness="1"
                Padding="4"
              >
                <ItemsControl ItemsSource="{Binding LogFilters}" Focusable="False">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}" Padding="6,3" Margin="2,1">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                          <Ellipse
                            Width="8"
                            Height="8"
                            Fill="{Binding LevelBrush}"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                          />
                          <TextBlock>
                            <Run Text="{Binding Name, Mode=OneWay}" />
                            <Run Text=" (" />
                            <Run Text="{Binding Count, Mode=OneWay}" />
                            <Run Text=")" />
                          </TextBlock>
                        </StackPanel>
                      </CheckBox>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Border>
            </Popup>
          </Grid>
        </Grid>

        <Button Width="32" Height="32" Margin="4,0,0,0" Command="{Binding RefreshLogsCommand}" ToolTip="Refresh">
          <iconPacks:PackIconPhosphorIcons Kind="ArrowsClockwise" Width="15" Height="15" />
        </Button>
        <Button Width="32" Height="32" Margin="4,0,0,0" Command="{Binding CopyLogsCommand}" ToolTip="Copy logs">
          <iconPacks:PackIconPhosphorIcons Kind="Copy" Width="15" Height="15" />
        </Button>
        <Button
          Width="32"
          Height="32"
          Margin="4,0,0,0"
          Command="{Binding OpenLogsFolderCommand}"
          ToolTip="Open logs folder"
        >
          <iconPacks:PackIconPhosphorIcons Kind="FolderOpen" Width="15" Height="15" />
        </Button>
      </StackPanel>
    </DockPanel>

    <Border
      Grid.Row="1"
      BorderBrush="{x:Static config:AppStyles.LogBorderBrush}"
      BorderThickness="1"
      CornerRadius="4"
      Padding="8"
    >
      <RichTextBox
        x:Name="LogViewer"
        IsReadOnly="True"
        IsReadOnlyCaretVisible="False"
        IsDocumentEnabled="False"
        BorderThickness="0"
        Background="Transparent"
        FontFamily="Consolas"
        FontSize="12"
        VerticalScrollBarVisibility="Auto"
        HorizontalScrollBarVisibility="Auto"
      />
    </Border>

    <local:StatusMessagePanel
      Grid.Row="1"
      HorizontalAlignment="Left"
      VerticalAlignment="Bottom"
      Margin="0,0,0,8"
      StatusMessage="{Binding StatusMessage}"
      StatusVisibility="{Binding StatusVisibility}"
    />
  </Grid>
</UserControl>
