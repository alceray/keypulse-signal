<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:config="clr-namespace:KeyPulse.Configuration"
>
  <!-- Circular icon button that fades in a hover disc (dashboard refresh / pause). -->
  <Style x:Key="RoundHoverIconButtonStyle" TargetType="Button">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Padding" Value="0" />
    <Setter Property="Width" Value="36" />
    <Setter Property="Height" Value="36" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="Button">
          <Grid Width="36" Height="36">
            <!-- Border grey, not the fainter fill, so the hover shows on white. -->
            <Ellipse
              x:Name="HoverCircle"
              Width="36"
              Height="36"
              Fill="{x:Static config:AppColorPalette.BorderBrush}"
              Opacity="0"
              HorizontalAlignment="Center"
              VerticalAlignment="Center"
            />
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
              <Setter TargetName="HoverCircle" Property="Opacity" Value="1" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <!-- Dashboard summary tiles. -->
  <Style x:Key="StatCardStyle" TargetType="Border">
    <Setter Property="Margin" Value="4" />
    <Setter Property="Padding" Value="10" />
    <Setter Property="BorderBrush" Value="{x:Static config:AppColorPalette.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="4" />
  </Style>

  <!-- Settings page section card / divider / title. -->
  <Style x:Key="SectionCardStyle" TargetType="Border">
    <Setter Property="BorderBrush" Value="{x:Static config:AppColorPalette.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="6" />
    <Setter Property="Padding" Value="14" />
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <Style x:Key="SectionDividerStyle" TargetType="Border">
    <Setter Property="Height" Value="1" />
    <Setter Property="Background" Value="{x:Static config:AppColorPalette.BorderBrush}" />
    <Setter Property="Margin" Value="0,0,0,12" />
  </Style>

  <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
    <Setter Property="Margin" Value="8,0,0,0" />
    <Setter Property="VerticalAlignment" Value="Center" />
    <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.PrimaryTextBrush}" />
  </Style>

  <!-- Troubleshooting toolbar action buttons. -->
  <Style x:Key="ToolbarButtonStyle" TargetType="Button">
    <Setter Property="Width" Value="32" />
    <Setter Property="Height" Value="32" />
    <Setter Property="Margin" Value="4,0,0,0" />
  </Style>

  <!-- Calendar day-of-week header cells. -->
  <Style x:Key="DayOfWeekHeaderStyle" TargetType="TextBlock">
    <Setter Property="HorizontalAlignment" Value="Center" />
    <Setter Property="FontWeight" Value="SemiBold" />
    <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.SecondaryTextBrush}" />
  </Style>

  <!-- Calendar device name: turns accent-colored while the device is connected. -->
  <Style x:Key="ConnectedDeviceNameStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.PrimaryTextBrush}" />
    <Style.Triggers>
      <DataTrigger Binding="{Binding IsConnected}" Value="True">
        <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.AccentBrush}" />
      </DataTrigger>
    </Style.Triggers>
  </Style>

  <!-- Calendar day-detail metric rows: left-hand label and right-hand value. -->
  <Style x:Key="DetailLabelStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.SecondaryTextBrush}" />
  </Style>

  <Style x:Key="DetailValueStyle" TargetType="TextBlock">
    <Setter Property="Foreground" Value="{x:Static config:AppColorPalette.PrimaryTextBrush}" />
    <Setter Property="TextAlignment" Value="Right" />
  </Style>

  <!-- Calendar day-detail metric bars (per-device connected / active / movement times). -->
  <Style x:Key="ActivityProgressBarStyle" TargetType="ProgressBar">
    <Setter Property="Height" Value="6" />
    <Setter Property="Margin" Value="0,0,0,6" />
    <Setter Property="Minimum" Value="0" />
    <Setter Property="FlowDirection" Value="LeftToRight" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Background" Value="{x:Static config:AppColorPalette.SurfaceBrush}" />
  </Style>

  <!-- Calendar day-detail per-device card. -->
  <Style x:Key="DayDetailCardStyle" TargetType="Border">
    <Setter Property="BorderBrush" Value="{x:Static config:AppColorPalette.BorderBrush}" />
    <Setter Property="BorderThickness" Value="1" />
    <Setter Property="CornerRadius" Value="3" />
    <Setter Property="Padding" Value="8" />
    <Setter Property="Margin" Value="0,0,0,8" />
  </Style>
</ResourceDictionary>
